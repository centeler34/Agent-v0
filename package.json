    "commander": "^14.0.3",
    "discord.js": "^14.26.0",
    "express": "^4.21.2",
    "grammy": "^1.41.1",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "lodash-es": "^4.18.1",
    "openai": "^6.33.0",
    "p-queue": "^9.1.0",
    "react": "^19.2.4",
